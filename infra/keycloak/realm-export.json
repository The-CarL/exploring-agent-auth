{
  "realm": "agentauth",
  "enabled": true,
  "displayName": "exploring-agent-auth demo realm",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 1800,

  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Engineer",
      "email": "alice@agentauth.local",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "attributes": {
        "role": ["employee"],
        "department": ["engineering"],
        "reports_to": ["bob"]
      },
      "realmRoles": ["default-roles-agentauth"]
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Manager",
      "email": "bob@agentauth.local",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "attributes": {
        "role": ["manager"],
        "department": ["engineering"],
        "reports_to": [""]
      },
      "realmRoles": ["default-roles-agentauth"]
    },
    {
      "username": "dave",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Dave",
      "lastName": "Admin",
      "email": "dave@agentauth.local",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "attributes": {
        "role": ["admin"],
        "department": ["platform"],
        "reports_to": [""]
      },
      "realmRoles": ["default-roles-agentauth"]
    }
  ],

  "clientScopes": [
    {
      "name": "agent-claims",
      "description": "Custom claims (role, department, reports_to) for the exploring-agent-auth demo",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "subject (sub)",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "role attribute",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "role",
            "claim.name": "role",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "department attribute",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "department",
            "claim.name": "department",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "reports_to attribute",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "reports_to",
            "claim.name": "reports_to",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "agent-client",
      "name": "Agent client (used by patterns 2-7)",
      "enabled": true,
      "publicClient": false,
      "secret": "agent-client-secret",
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "consentRequired": false,
      "fullScopeAllowed": true,
      "attributes": {
        "standard.token.exchange.enabled": "true",
        "client.session.idle.timeout": "0",
        "client.session.max.lifespan": "0"
      },
      "protocolMappers": [
        {
          "name": "audience: expense-service-client",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "expense-service-client",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "audience: document-service-client",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "document-service-client",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "agent-claims"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "expense-service-client",
      "name": "Expense service (token audience for patterns 5-7)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "consentRequired": false,
      "attributes": {}
    },
    {
      "clientId": "document-service-client",
      "name": "Document service (token audience for patterns 5-7)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "consentRequired": false,
      "attributes": {}
    },
    {
      "clientId": "user-direct-client",
      "name": "User-direct client (used by pattern 8 only, 3LO consent flow)",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "consentRequired": true,
      "rootUrl": "http://localhost:8765",
      "redirectUris": [
        "http://localhost:8765/*",
        "urn:ietf:wg:oauth:2.0:oob"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "agent-claims"
      ],
      "optionalClientScopes": []
    }
  ]
}
