# OpenAI API key — required by shared/agent.py for tool calling.
# The agent uses chat.completions with a small model; tens of cents per full notebook run.
OPENAI_API_KEY=sk-...

# Default model the agent uses. Override if you want to swap.
OPENAI_MODEL=gpt-4o-mini

# Keycloak — only override if you've changed docker-compose.yml port mappings.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=agentauth

# Agent client credentials, must match infra/keycloak/realm-export.json
AGENT_CLIENT_ID=agent-client
AGENT_CLIENT_SECRET=agent-client-secret

# Backend service URLs (host-side, what notebooks use)
EXPENSE_SERVICE_URL=http://localhost:8001
DOCUMENT_SERVICE_URL=http://localhost:8002

# OPA URL (host-side)
OPA_URL=http://localhost:8181

# Shared API key the agent uses in pattern 1 (ServiceCredentialAuth) and that
# the FastAPI services accept as the "service credential" auth method.
SHARED_SERVICE_API_KEY=dev-shared-api-key
