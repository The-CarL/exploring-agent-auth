# OpenAI API key, required by framework/agent.py for tool calling.
# The agent uses the OpenAI Agents SDK with a small model; a few cents per full notebook run.
OPENAI_API_KEY=sk-...

# Default model the agent uses. Override if you want to swap.
# gpt-5-nano is the cheapest current model that supports tool calling
# ($0.05/M input, $0.40/M output as of April 2026). If tool calling misbehaves,
# gpt-4.1-nano is a safe fallback ($0.10/M input, $0.40/M output).
OPENAI_MODEL=gpt-5-nano

# Keycloak, only override if you've changed docker-compose.yml port mappings.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=agentauth

# Agent client credentials, must match infra/keycloak/realm-export.json
AGENT_CLIENT_ID=agent-client
AGENT_CLIENT_SECRET=agent-client-secret

# OPA URL (host-side)
OPA_URL=http://localhost:8181

# Shared API key the agent uses in pattern 1 and that the services accept
# as the "service credential" auth method.
SHARED_SERVICE_API_KEY=dev-shared-api-key
